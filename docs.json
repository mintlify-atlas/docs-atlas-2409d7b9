{
  "$schema": "https://mintlify.com/docs.json",
  "name": "webpack-doc-kit",
  "theme": "aspen",
  "colors": {
    "primary": "#1a73e8",
    "light": "#4fc3f7",
    "dark": "#0d47a1"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/webpack/webpack-doc-kit"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/webpack/webpack-doc-kit"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "How It Works",
            "pages": [
              "how-it-works/overview",
              "how-it-works/typedoc-pipeline",
              "how-it-works/webpack-sync"
            ]
          },
          {
            "group": "Configuration",
            "pages": ["configuration/generate-md", "configuration/tsconfig"]
          },
          {
            "group": "Plugins",
            "pages": [
              "plugins/overview",
              "plugins/processor",
              "plugins/theme"
            ]
          },
          {
            "group": "Scripts & CI",
            "pages": ["scripts/npm-scripts", "scripts/github-actions"]
          },
          {
            "group": "Contributing",
            "pages": ["contributing"]
          }
        ]
      }
    ]
  }
}
